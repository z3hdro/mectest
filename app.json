{
  "expo": {
    "name": "mectest",
    "slug": "mectest",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mectest",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mectest"
    },
    "android": {
      "package": "com.mectest",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {},
    "plugins": [
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
